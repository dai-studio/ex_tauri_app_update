<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:dai="https://diagram.app/schema/dai/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_1" name="Blank" targetNamespace="https://diagram.app/workflow">
  <bpmn:process id="Process_1" name="Blank" isExecutable="false">
    <bpmn:extensionElements>
      <dai:workflowMeta description="Generate a blank application with update capability" defaultModel="gpt-4o" targetLanguage="" targetFramework="" version="1.0" />
    </bpmn:extensionElements>
    <bpmn:subProcess id="Activity_1tpgm09" name="system">
      <bpmn:task id="Activity_12b7ldu" name="purpose" dai:stepType="context" dai:notes="Build a desktop application with self-update capability. The app should demonstrate the full update lifecycle: checking for a new version, downloading with live progress, and installing with an automatic restart." />
      <bpmn:task id="Activity_1h7gk12" name="Rust" dai:stepType="dependency" dai:notes="Systems language for the Tauri backend. Handles native OS integration, IPC commands, and all update logic via tauri-plugin-updater." />
      <bpmn:task id="Activity_0d0k1tx" name="Tauri 2" dai:stepType="dependency" dai:notes="Desktop shell. Provides native window management, file system access, and IPC between the Rust backend and the SvelteKit frontend." />
      <bpmn:task id="Activity_12t4czt" name="self-update" dai:stepType="dependency" dai:notes="Use tauri-plugin-updater v2 for self-update over HTTPS. Implement check_update and apply_update as Tauri commands in Rust. Stream download progress back to the frontend via a Tauri IPC Channel." />
      <bpmn:task id="Activity_0wiouy0" name="svelte-kit" dai:stepType="dependency" dai:notes="SvelteKit 2 + Svelte 5 frontend in SPA mode. Use @sveltejs/adapter-static with fallback to index.html. SSR must be disabled (export const ssr = false in +layout.ts)." />
      <bpmn:task id="Rule_no_key_commit" name="No Committed Keys" dai:stepType="rule" dai:notes="The private signing key must never be committed to version control. If it is lost, future updates cannot be signed and existing installs cannot be updated. Store the key at ~/.tauri/blank.key and load it via the TAURI_SIGNING_PRIVATE_KEY environment variable at build time." />
      <bpmn:task id="Rule_spa_mode" name="SPA Mode Required" dai:stepType="rule" dai:notes="SvelteKit must use adapter-static with ssr=false. Tauri has no Node.js server, so server-side rendering is not supported. Configure svelte.config.js to use adapter-static with fallback: 'index.html'." />
      <bpmn:task id="Rule_https_only" name="HTTPS Only" dai:stepType="rule" dai:notes="Update endpoints must be served over HTTPS in production. HTTP is only permitted during local development using the dangerousInsecureTransportProtocol flag in tauri.conf.json." />
      <bpmn:task id="Step_update_lifecycle" name="Update Lifecycle" dai:stepType="step" dai:notes="The full update flow: (1) check the HTTPS endpoint for a new version, (2) if available, download the artifact and stream progress events (Started, Progress, Finished) back to the frontend via Channel, (3) verify the minisign signature, (4) install the update, (5) restart the app." />
    </bpmn:subProcess>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_1">
      <bpmndi:BPMNShape id="Activity_1tpgm09_di" bpmnElement="Activity_1tpgm09" isExpanded="true">
        <dc:Bounds x="-260" y="-210" width="930" height="430" />
        <bpmndi:BPMNLabel />

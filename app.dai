        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Rule_no_key_commit_di" bpmnElement="Rule_no_key_commit">
        <dc:Bounds x="-240" y="60" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Rule_spa_mode_di" bpmnElement="Rule_spa_mode">
        <dc:Bounds x="-120" y="60" width="100" height="80" />
